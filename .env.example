# Токен от @BotFather
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# ID админов через запятую (для статистики и модерации)
ADMIN_IDS=123456789

# Цены в Telegram Stars
PRICE_BEST_TEAM=5
PRICE_HIGHLIGHT=7
PRICE_CONTACT_PACK=3
PRICE_PRO_SUBSCRIPTION=15
PRICE_SINGLE_CONTACT=2
PRICE_PREMIUM_APPLICATION=3

# База данных PostgreSQL (обязательно для продакшена)
# Формат: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://user:password@host:5432/database

# Публичный HTTPS-адрес Mini App.
# На Render можно не задавать — подставится RENDER_EXTERNAL_URL автоматически.
# Локально: ngrok/localtunnel → https-адрес сюда.
WEBAPP_URL=https://your-app.onrender.com

# На чём поднимается локальный веб-сервер (обычно менять не нужно)
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080
